    {
      "name": "01 - Auth JWT REST",
      "description": "Ejecuta Register y luego Login. El login guarda el JWT en la variable de colección {{jwt}}.",
      "item": [
        {
          "name": "Register Staff - Gateway",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{gatewayBase}}/auth/register",
            "description": "Genera un usuario único y lo registra por Gateway.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Postman\",\n  \"lastName\": \"Tester\",\n  \"addressId\": 5,\n  \"email\": \"{{testEmail}}\",\n  \"storeId\": 1,\n  \"active\": true,\n  \"username\": \"{{testUsername}}\",\n  \"password\": \"{{testPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now();",
                  "pm.collectionVariables.set(\"testUsername\", \"postman_\" + suffix);",
                  "pm.collectionVariables.set(\"testEmail\", \"postman_\" + suffix + \"@sakila.com\");",
                  "pm.collectionVariables.set(\"testPassword\", \"password123\");",
                  "console.log(\"Usuario de prueba generado:\", pm.collectionVariables.get(\"testUsername\"));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Respuesta HTTP válida\", function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201, 204]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Gateway (guarda JWT)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{gatewayBase}}/auth/login",
            "description": "Inicia sesión por Gateway y guarda el JWT como variable de colección.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{testUsername}}\",\n  \"password\": \"{{testPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login respondió 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "let token = \"\";",
                  "try {",
                  "  const data = pm.response.json();",
                  "  if (typeof data === \"string\") {",
                  "    token = data;",
                  "  } else {",
                  "    token = data.token || data.jwt || data.accessToken || data.access_token || \"\";",
                  "  }",
                  "} catch (e) {",
                  "  token = pm.response.text();",
                  "}",
                  "",
                  "token = String(token || \"\").trim().replace(/^\"|\"$/g, \"\");",
                  "",
                  "pm.test(\"JWT recibido\", function () {",
                  "  pm.expect(token.length).to.be.above(20);",
                  "});",
                  "",
                  "pm.collectionVariables.set(\"jwt\", token);",
                  "console.log(\"JWT guardado en variable de colección jwt:\", token);"
                ]
              }
            }
          ]
        },
