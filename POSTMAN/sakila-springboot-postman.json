            ],
            "url": "{{gatewayBase}}/business/graphql",
            "description": "Consulta GraphQL por Gateway con variable id.",
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query StoreById($id: ID!) {\n  storeById(id: $id) {\n    id\n    managerStaffId\n    addressId\n  }\n}",
