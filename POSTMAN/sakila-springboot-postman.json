    {
      "name": "03 - Business GraphQL",
      "description": "Estos requests están configurados con Body > GraphQL, no como JSON raw.",
      "item": [
        {
          "name": "GraphQL allStores - Gateway",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt}}"
              }
            ],
            "url": "{{gatewayBase}}/business/graphql",
            "description": "Consulta GraphQL por Gateway.",
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query AllStores {\n  allStores {\n    id\n    managerStaffId\n    addressId\n  }\n}",
                "variables": "{}"
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Respuesta GraphQL válida\", function () {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data).to.have.property(\"data\");",
                  "  pm.expect(data.errors, JSON.stringify(data.errors)).to.be.undefined;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GraphQL storeById - Gateway",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
