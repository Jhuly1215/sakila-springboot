    {
      "name": "04 - Reports WebSocket",
      "description": "Postman no ejecuta WebSocket en Collection Runner. Abre el request y presiona Connect. Mensaje de prueba: get-sales",
      "item": [
        {
          "name": "WS Reports - Gateway con token",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{reportsWsGateway}}?token={{jwt}}",
            "description": "Conecta por Gateway. Después de conectar, envía el mensaje de texto: get-sales"
          }
        },
        {
          "name": "WS Reports - Direct Reports Service",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{reportsWsDirect}}",
            "description": "Conecta directo al reports-service. Después de conectar, envía el mensaje de texto: get-sales"
          }
        },
        {
          "name": "Mensaje que debes enviar manualmente",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{gatewayBase}}",
            "description": "En el request WebSocket, envía manualmente este texto exacto: get-sales"
          }
        }
      ]
    },
    {
      "name": "05 - Seguridad / pruebas negativas",
      "item": [
        {
          "name": "Customer sin token - Gateway debe fallar",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{gatewayBase}}/customer/all",
            "description": ""
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Debe rechazar sin token\", function () {",
                  "  pm.expect([401, 403]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Customer sin token - Direct puede depender de configuración",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{customerBase}}/customer/all",
            "description": "Si el servicio directo no tiene filtro de seguridad, podría devolver 200."
          }
        },
        {
          "name": "GraphQL sin token - Gateway debe fallar si el Gateway filtra",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{gatewayBase}}/business/graphql",
            "description": "Puede fallar con 401/403 si el Gateway valida JWT.",
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query AllStores {\n  allStores {\n    id\n    managerStaffId\n    addressId\n  }\n}",
                "variables": "{}"
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Respuesta GraphQL válida\", function () {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data).to.have.property(\"data\");",
                  "  pm.expect(data.errors, JSON.stringify(data.errors)).to.be.undefined;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
