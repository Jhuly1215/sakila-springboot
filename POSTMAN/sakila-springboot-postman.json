      "item": [
        {
          "name": "Nota - gRPC no existe en el repo actual",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{gatewayBase}}",
            "description": "Para probar gRPC en Postman necesitas New > gRPC, importar un .proto real y colocar host:puerto gRPC. Este proyecto expone REST, GraphQL y WebSocket; SOAP queda fuera de esta colección porque se probará con SoapUI."
          }
        }
      ]
    }
